{
  "name": "git-db-sync",
  "version": "0.1.0",
  "description": "Git-to-PostgreSQL sync pipeline for structured Markdown artifact repositories",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli/reqsync.ts",
    "dev:gen": "tsx src/cli/reqgen.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "bin": {
    "reqsync": "./dist/cli/reqsync.js",
    "reqgen": "./dist/cli/reqgen.js"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.0.0",
    "handlebars": "^4.7.8",
    "mdast-util-to-string": "^4.0.0",
    "pg": "^8.13.0",
    "remark-parse": "^11.0.0",
    "seedrandom": "^3.0.5",
    "simple-git": "^3.27.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.30.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
